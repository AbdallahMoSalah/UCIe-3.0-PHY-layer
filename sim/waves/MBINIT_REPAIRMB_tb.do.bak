onerror {resume}
quietly WaveActivateNextPane {} 0
add wave -noupdate -divider {System Signals}
add wave -noupdate /MBINIT_REPAIRMB_tb/clk
add wave -noupdate /MBINIT_REPAIRMB_tb/rst_n
add wave -noupdate -color Gold /MBINIT_REPAIRMB_tb/mb_repairmb_enable
add wave -noupdate -color Green /MBINIT_REPAIRMB_tb/mb_repairmb_done
add wave -noupdate -color Red /MBINIT_REPAIRMB_tb/mb_repairmb_error
add wave -noupdate -color Red /MBINIT_REPAIRMB_tb/timeout_error
add wave -noupdate -divider {State Machine}
add wave -noupdate -color Cyan /MBINIT_REPAIRMB_tb/dut/current_state
add wave -noupdate -color Cyan /MBINIT_REPAIRMB_tb/dut/next_state
add wave -noupdate -divider {RX Message Interface}
add wave -noupdate -color Magenta /MBINIT_REPAIRMB_tb/mb_repairmb_rx_valid
add wave -noupdate -color Magenta /MBINIT_REPAIRMB_tb/mb_repairmb_rx_msg_id
add wave -noupdate -color Magenta -radix hexadecimal /MBINIT_REPAIRMB_tb/mb_repairmb_rx_MsgInfo
add wave -noupdate -divider {TX Message Interface}
add wave -noupdate -color Yellow /MBINIT_REPAIRMB_tb/mb_repairmb_tx_valid
add wave -noupdate -color Yellow /MBINIT_REPAIRMB_tb/mb_repairmb_tx_msg_id
add wave -noupdate -color Yellow -radix hexadecimal /MBINIT_REPAIRMB_tb/mb_repairmb_tx_MsgInfo
add wave -noupdate -divider {D2C Point Test}
add wave -noupdate -color Cyan /MBINIT_REPAIRMB_tb/d2c_test_if/tx_pt_en
add wave -noupdate -color Green /MBINIT_REPAIRMB_tb/d2c_test_if/test_d2c_done
add wave -noupdate -color Red -radix hexadecimal /MBINIT_REPAIRMB_tb/d2c_test_if/d2c_perlane_err
add wave -noupdate -divider {Lane Map Decision}
add wave -noupdate -color Cyan -radix binary /MBINIT_REPAIRMB_tb/dut/mb_rx_perlane_result
add wave -noupdate -color Yellow -radix binary /MBINIT_REPAIRMB_tb/dut/local_lane_map
add wave -noupdate -color Magenta -radix binary /MBINIT_REPAIRMB_tb/dut/partner_lane_map
add wave -noupdate -color Green -radix binary /MBINIT_REPAIRMB_tb/dut/final_lane_map
add wave -noupdate -color Green -radix binary /MBINIT_REPAIRMB_tb/dut/final_lane_map_r
add wave -noupdate -color Orange -radix binary /MBINIT_REPAIRMB_tb/dut/prev_lane_map
add wave -noupdate -color Red /MBINIT_REPAIRMB_tb/dut/degrade_not_possible
add wave -noupdate -color Red /MBINIT_REPAIRMB_tb/dut/degrade_not_possible_r
add wave -noupdate -divider {Retry Logic}
add wave -noupdate -color Orange /MBINIT_REPAIRMB_tb/dut/retry_start
add wave -noupdate -color Orange /MBINIT_REPAIRMB_tb/dut/retry_done
add wave -noupdate -color Yellow /MBINIT_REPAIRMB_tb/dut/width_changed_r
TreeUpdate [SetDefaultTree]
WaveRestoreCursors {{Cursor 1} {0 ps} 0}
quietly wave cursor active 1
configure wave -namecolwidth 173
configure wave -valuecolwidth 150
configure wave -justifyvalue left
configure wave -signalnamewidth 1
configure wave -snapdistance 10
configure wave -datasetprefix 0
configure wave -rowmargin 4
configure wave -childrowmargin 2
configure wave -gridoffset 0
configure wave -gridperiod 1
configure wave -griddelta 40
configure wave -timeline 0
configure wave -timelineunits ns
update
WaveRestoreZoom {0 ps} {3068150 ps}
